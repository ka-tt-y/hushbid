{
  "name": "@hushbid/sdk",
  "version": "0.1.0",
  "description": "HushBid Protocol SDK for private price discovery",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "viem": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "keywords": [
    "hushbid",
    "hush-bid",
    "auction",
    "privacy",
    "chainlink",
    "ccip",
    "web3"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hushbid/hushbid-protocol"
  }
}
